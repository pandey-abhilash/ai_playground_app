{
  "name": "ai_playground_app",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run --filter server dev\" \"bun run --filter client dev\"",
    "dev:server": "bun run --filter server dev",
    "dev:client": "bun run --filter client dev",
    "build": "bun run --filter client build",
    "build:client": "bun run --filter client build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^10.0.3",
    "typescript": "~6.0.2"
  }
}
